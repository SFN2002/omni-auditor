# ═══════════════════════════════════════════════════════════════════════════
# Omni-Auditor SaaS Dashboard — Environment Variables Template
# Copy this file to .env and fill in the actual values for your environment.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/omniauditor

# ─── Redis ────────────────────────────────────────────────────────────────
# Primary Redis connection (caching, sessions)
REDIS_URL=redis://redis:6379/0

# Celery broker (message queue for background tasks)
CELERY_BROKER_URL=redis://redis:6379/1

# ─── GitHub OAuth ─────────────────────────────────────────────────────────
# GitHub OAuth app credentials — create at https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Webhook secret for verifying GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ─── JWT Authentication ───────────────────────────────────────────────────
# Secret key for signing JWT tokens — MUST be changed in production!
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Token expiration time in hours
JWT_EXPIRATION_HOURS=24

# ─── Omni-Auditor Engine ──────────────────────────────────────────────────
# Path to the omni-auditor CLI tool inside the container
OMNI_AUDITOR_PATH=/app/omni-auditor

# ─── Frontend / CORS ──────────────────────────────────────────────────────
# Frontend URL used for CORS configuration
FRONTEND_URL=http://localhost:5173

# API URL for the frontend (Vite build-time variable)
VITE_API_URL=http://localhost:8000

# ─── Environment Settings ─────────────────────────────────────────────────
# Environment: development, staging, or production
ENVIRONMENT=development

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# ─── Docker Compose Overrides ─────────────────────────────────────────────
# These are used by docker-compose.yml for local development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=omniauditor
