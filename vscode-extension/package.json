{
  "name": "omni-auditor",
  "displayName": "Omni-Auditor",
  "version": "0.1.0",
  "description": "VS Code extension for Omni-Auditor spectral Python analysis",
  "publisher": "omni-auditor",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omni-auditor/omni-auditor"
  },
  "bugs": {
    "url": "https://github.com/omni-auditor/omni-auditor/issues"
  },
  "homepage": "https://github.com/omni-auditor/omni-auditor#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Linters",
    "Debuggers"
  ],
  "keywords": [
    "python",
    "security",
    "static-analysis",
    "spectral-graph"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.py"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "omni-auditor.analyzeCurrentFile",
        "title": "Analyze Current File",
        "category": "Omni-Auditor",
        "icon": "$(shield)"
      },
      {
        "command": "omni-auditor.showRiskDashboard",
        "title": "Show Risk Dashboard",
        "category": "Omni-Auditor",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "omni-auditor.analyzeCurrentFile",
          "when": "editorLangId == python",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "omni-auditor.analyzeCurrentFile",
          "when": "editorLangId == python"
        },
        {
          "command": "omni-auditor.showRiskDashboard",
          "when": "editorLangId == python"
        }
      ]
    },
    "configuration": {
      "title": "Omni-Auditor",
      "properties": {
        "omniAuditor.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python 3.10+ executable"
        },
        "omniAuditor.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Omni-Auditor project root (directory containing src/main.py)"
        },
        "omniAuditor.threshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "CRITICAL risk tier threshold forwarded to --threshold"
        },
        "omniAuditor.autoAnalyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run Omni-Auditor analysis when saving a Python file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
